# Dependencies / build artifacts
node_modules/
.venv/
dist/
.runtime/
artifacts/
bin/excli
bin/backups/
# excli release binaries are NOT redistributed here — they are fetched from the
# pinned upstream source and checksum-verified at build/install time. Never
# commit them; only vendor/excli/source.env + the checksums file are tracked.
vendor/excli/*.tar.gz
vendor/excli/*.exe
# Playwright browser-smoke outputs (never commit)
test-results/
playwright-report/

# Runtime / local state (never commit)
.env
config.json
secrets.json
# App-managed Graphiti embedder overrides (written from Settings → Memory).
graphiti/runtime/
*.log
app.pid
workspaces/
data/
eval/reports/
.claude/
.DS_Store

# NOTE: excli archives are fetched + checksum-verified at build/install time
# (see vendor/excli/source.env and scripts/fetch-excli.sh), not committed.
# .env.example is the template (no secrets) and IS committed.
