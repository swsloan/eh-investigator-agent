# Dependencies / build artifacts
node_modules/
.venv/
dist/
.runtime/
artifacts/
bin/excli
bin/backups/
# Playwright browser-smoke outputs (never commit)
test-results/
playwright-report/

# Runtime / local state (never commit)
.env
config.json
secrets.json
# App-managed Graphiti embedder overrides (written from Settings → Memory).
graphiti/runtime/
*.log
app.pid
workspaces/
data/
eval/reports/
.claude/
.DS_Store

# NOTE: vendor/excli/ archives ARE committed — the Dockerfile extracts the
# platform-matched excli binary from them at build time. .env.example is the
# template (no secrets) and IS committed.
