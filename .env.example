# ─────────────────────────────────────────────────────────────────────────────
# ExtraHop Investigation Agent — environment template
#
# Copy to `.env` (gitignored) and fill in. `docker compose` reads this file for
# ${VAR} interpolation; the app also reads it when run directly.
#
# PRECEDENCE: values set in the in-app Settings UI win over these. Secrets you
# set in Settings are stored in the secret layer (secrets.json volume) and are
# scrubbed from the model's process env. You can leave the secret lines below
# blank and set them in Settings instead — either works.
#
# Do NOT commit `.env`. Keep it 0600. Rotate any key that has been shared.
# ─────────────────────────────────────────────────────────────────────────────


# ── RevealX connection ───────────────────────────────────────────────────────
# Pick ONE of the two blocks below (Enterprise API key, or 360 client creds).

# RevealX Enterprise (on-prem appliance)
EXTRAHOP_HOST=eda.example.com
EXTRAHOP_API_KEY=
EXTRAHOP_INSECURE=true            # true if the appliance uses a self-signed cert

# — or — RevealX 360 (SaaS)
# EXTRAHOP_HOST=tenant.api.cloud.extrahop.com
# EXTRAHOP_CLIENT_ID=
# EXTRAHOP_CLIENT_SECRET=
# EXTRAHOP_INSECURE=false


# ── Claude / Anthropic ───────────────────────────────────────────────────────
# API key for the Claude Code agent (apiKey sign-in mode) AND for Graphiti
# memory extraction (always via the in-app /memory-llm proxy). Leave blank and
# set it in Settings → Memory if you prefer not to keep it on disk here.
#
# For a Claude Pro/Max SUBSCRIPTION instead: leave this blank, run
# `claude setup-token` on a machine with a browser, paste the token in
# Settings → Agent, and switch sign-in to Subscription. (In-container /login
# does not work — the OAuth callback can't reach the container.)
ANTHROPIC_API_KEY=


# ── Long-term memory (Graphiti) ──────────────────────────────────────────────
# MEMORY_ENABLED / MEMORY_MCP_URL are set for you in docker-compose.yml.
#
# Per-environment namespace for the knowledge graph. Leave blank to derive it
# from the RevealX host automatically. MUST be alphanumeric (FalkorDB/RediSearch
# rejects hyphens and dots) if you set it explicitly.
EH_MEMORY_GROUP_ID=

# Shared token gating the app's /memory-llm proxy (Graphiti → Anthropic).
# Any non-empty string; only used between the two local containers.
EH_MEMORY_PROXY_TOKEN=eh-memory-proxy-local


# ── Graphiti stack tuning (advanced — defaults are sensible) ─────────────────
# LLM used by Graphiti to extract entities/relationships from investigations.
MODEL_NAME=claude-sonnet-5

# Local embedder (Ollama, OpenAI-compatible). Default matches config.yaml.
EMBEDDER_MODEL=nomic-embed-text

# Concurrency for Graphiti extraction; lower it on a small host.
SEMAPHORE_LIMIT=5

# FalkorDB graph store.
FALKORDB_DATABASE=extrahop
FALKORDB_PASSWORD=

# Only used by the local-LLM comparison overlay (docker-compose.qwen.yml),
# where Graphiti's LLM points at Ollama instead of Anthropic.
# OPENAI_API_URL=http://ollama:11434/v1
# OPENAI_API_KEY=ollama


# ── Local (non-Docker) run overrides — ignore for `docker compose` ───────────
# PORT=3100
# HOST=127.0.0.1                  # compose sets 0.0.0.0 inside the container
# EH_CONFIG_PATH=./config.json    # compose uses /app/data/config.json (volume)
# EH_SECRETS_PATH=./secrets.json  # compose uses /app/data/secrets.json (volume)
# MEMORY_ENABLED=1
# MEMORY_MCP_URL=http://localhost:8000/mcp
# WEASYPRINT_BIN=weasyprint       # path to weasyprint for PDF export
