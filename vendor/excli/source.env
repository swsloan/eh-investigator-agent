# Pinned upstream source for the ExtraHop CLI (`excli`).
#
# We do NOT redistribute the excli binaries: the upstream repo
# https://github.com/ExtraHop/agent-cli carries no license granting
# redistribution (unlike ExtraHop/agent-skills, which is MIT). So instead of
# committing the binaries into this repository, the Docker build and the local
# bootstrap FETCH the architecture-matched archive from the pinned commit below
# and verify it against the committed checksums before use.
#
# To move to a newer excli: bump EXCLI_COMMIT to the agent-cli commit that
# published it, set EXCLI_VERSION to that release's version-hash, and replace the
# committed excli_<version>_checksums.txt with that release's checksums.
EXCLI_REPO="ExtraHop/agent-cli"
EXCLI_COMMIT="bf5c541bf3880a41ef1fc5198f913993cf3a2b9a"
EXCLI_VERSION="0.0.111-2fdebedca0"
